# frozen_string_literal: true

# Fake query to simulate fetching user data.
class User::Queries::FindUserQuery < RailsQuery::Query
  ttl 30.seconds

  key do |id|
    [ "user", id ]
  end

  def resolve(id)
    {
      id: id,
      name: "User #{id}",
      fetched_at: Time.current
    }
  end
end
